# Public (client-side)
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Agent contracts (deployed on Monad testnet)
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
FRAUD_REPORT_REGISTRY_ADDRESS=

# Deployer (forge scripts only)
DEPLOYER_PRIVATE_KEY=

# Agent URLs — must be publicly reachable for Vercel deployment
# For local dev: http://localhost:3001 / http://localhost:3002
# For production: use a hosted URL (e.g. Railway, Fly.io, or any server)
FRAUD_AGENT_URL=http://localhost:3001
DEVELOPER_AGENT_URL=http://localhost:3002

# Fraud Detection Agent
FRAUD_AGENT_PRIVATE_KEY=
FRAUD_AGENT_PORT=3001

# Developer Agent
DEVELOPER_AGENT_PRIVATE_KEY=
DEVELOPER_AGENT_PORT=3002

# NVIDIA AI (for agent intelligence)
NVIDIA_API_KEY=
